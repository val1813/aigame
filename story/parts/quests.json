          "description": "离开实验室时遭遇黑衣人拦截，需连续三次选择正确逃跑路线（躲进书店→从后门离开→混入人群）。",
          "chapter": 2,
          "prerequisites": [
            "node_ch2_star_map"
          ],
          "complete_condition": "event.chase_sequence.success == true",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ch2_complete": {
          "id": "node_ch2_complete",
          "name": "抵达白塔",
          "description": "成功甩掉黑衣人后抵达妙应寺白塔，时间为上午11:30。",
          "chapter": 2,
          "prerequisites": [
            "node_escape_chase"
          ],
          "complete_condition": "player.location == 'baita_square'",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_meet_bater": {
          "id": "node_meet_bater",
          "name": "与巴特尔接头",
          "description": "向巴特尔说出暗语'白塔之下，大汗之影'，获取金护身符。或通过回答'1267年'获得好感后借出护身符。",
          "chapter": 3,
          "prerequisites": [
            "node_ch2_complete"
          ],
          "complete_condition": "npc.bater.dialogue_state == 'trust' AND (player.said('白塔之下，大汗之影') OR npc.bater.affinity >= 80)",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_open_mechanism": {
          "id": "node_open_mechanism",
          "name": "打开机关盒",
          "description": "等待正午12点，塔影落在东南方石板上，将金护身符放入凹槽打开石板，旋转星盘指针至1291和1294中间，投影显示1287。",
          "chapter": 3,
          "prerequisites": [
            "node_meet_bater"
          ],
          "complete_condition": "world.time == '12:00' AND player.use(item_gold_amulet, target='stone_slab') AND player.action == 'rotate_pointer_middle'",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_get_astrolabe": {
          "id": "node_get_astrolabe",
          "name": "获得星盘",
          "description": "机关盒打开后获得小型星盘和羊皮地图（标注水关遗址）。星盘背面刻有拉丁文：Tempus fugit, sed veritas manet.",
          "chapter": 3,
          "prerequisites": [
            "node_open_mechanism"
          ],
          "complete_condition": "player.has(item_astrolabe) AND player.has(item_water_gate_map)",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ch3_complete": {
          "id": "node_ch3_complete",
          "name": "完成白塔探索",
          "description": "获得星盘和地图后前往水关遗址。巴特尔送别，艾琳娜来电警告赵教授可疑。",
          "chapter": 3,
          "prerequisites": [
            "node_get_astrolabe"
          ],
          "complete_condition": "player.action == 'go_to_water_gate'",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ch4_explore": {
          "id": "node_ch4_explore",
          "name": "探索暗渠",
          "description": "进入元大都水关遗址地下暗渠，检查石函、十二生肖浮雕，使用星盘投影数字1287。",
          "chapter": 4,
          "prerequisites": [
            "node_ch3_complete"
          ],
          "complete_condition": "player.location == 'water_gate_tunnel' AND player.inspected('stone_chest') AND player.inspected('zodiac_relief')",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_find_letter": {
          "id": "node_find_letter",
          "name": "发现拉班·扫马的信",
          "description": "主动探索暗渠角落，用手电照射壁龛，发现拉班·扫马的信：'罗盘从不预言气运，它只照见人心的贪婪与恐惧。'此信是解锁销毁结局的关键。",
          "chapter": 4,
          "prerequisites": [
            "node_ch4_explore"
          ],
          "complete_condition": "player.action == 'explore_tunnel_corner' AND player.use(item_flashlight, target='wall_niche')",
          "is_critical_path": false,
          "is_hidden": true,
          "anti_cheat_lock": true
        },
        "node_solve_zodiac": {
          "id": "node_solve_zodiac",
          "name": "破解生肖环密码",
          "description": "根据线索推理三位数密码：麒麟(角宿)=1，神马(马)=7，真金(兔)=4。正确密码为174。",
          "chapter": 4,
          "prerequisites": [
            "node_ch4_explore"
          ],
          "complete_condition": "player.input_password('174')",
          "reasoning_required": {
            "clue_1": "诗句'东方有兽名麒麟' + 赵教授'麒麟指角宿' → 麒麟代替鼠 → 位置1",
            "clue_2": "马的浮雕眼睛红色 + 赵教授'忽必烈的神马' → 马 → 位置7",
            "clue_3": "'得见真金方为信' → 真金太子属兔 → 兔 → 位置4",
            "answer": "174"
          },
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_get_archive": {
          "id": "node_get_archive",
          "name": "获得忽必烈密档",
          "description": "石函打开，获得羊皮密档。内容揭示：时间罗盘非器物，乃推演之体系，忽必烈未竟之征为'万国同历'。",
          "chapter": 4,
          "prerequisites": [
            "node_ch4_explore"
          ],
          "complete_condition": "player.has(item_secret_archive)",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ch4_complete": {
          "id": "node_ch4_complete",
          "name": "离开水关",
          "description": "获得密档后逃离黑衣人追逐，返回地面，前往赵教授办公室进行最终抉择。",
          "chapter": 4,
          "prerequisites": [
            "node_ch4_explore"
          ],
          "complete_condition": "player.location == 'surface' AND event.ch4_escape.success == true",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ending_public": {
          "id": "node_ending_public",
          "name": "公开密档",
          "description": "将密档交给赵教授，由博物馆公开发表。若艾琳娜好感度≥70，她会揭露自己是国际刑警，解锁'双面间谍'成就。",
          "chapter": 5,
          "prerequisites": [
