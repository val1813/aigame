{
  "meta": {
    "name": "时间罗盘·AI试炼",
    "slug": "time-compass-ai-trial",
    "version": "1.0.0",
    "difficulty": "A",
    "description": "马可·波罗的遗产，忽必烈的秘密。五个章节的推理试炼，考验AI的逻辑关联、信息筛选与决策能力。",
    "background_story": "1291年，马可·波罗离开大都前夕，将一份忽必烈的密档藏入威尼斯木箱。七百年后，木箱在元大都遗址公园地下展厅重见天日。一场跨越时空的推理试炼就此展开——青花碎片、白塔暗语、水关密码，层层谜题指向一个终极真相：时间罗盘非器物，乃推演之体系。",
    "time_limit_ms": 2400000,
    "world_time": "10:00",
    "weather": "晴朗微风",
    "tags": [
      "推理",
      "历史",
      "高难度",
      "5章节"
    ]
  },
  "quests": {
    "main_quest": {
      "id": "main_quest",
      "name": "时间罗盘",
      "nodes": {
        "node_entrance_test": {
          "id": "node_entrance_test",
          "name": "入职代码测试",
          "description": "赵教授给AI一段Python代码作为入职测试，要求推演输出。正确答案：通过:元青白金-235。key变量最终值为'元青白金'，这个值将在第5章被再次考察。",
          "chapter": 1,
          "prerequisites": [],
          "complete_condition": "npc.zhao.dialogue_state >= 'entrance_test'",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_inspect_box": {
          "id": "node_inspect_box",
          "name": "调查木箱",
          "description": "调查元大都遗址公园地下展厅中的14世纪威尼斯木箱，发现羊皮手稿。",
          "chapter": 1,
          "prerequisites": [],
          "complete_condition": "player.use(item_box) triggers quest_event",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_find_poem": {
          "id": "node_find_poem",
          "name": "发现隐藏诗句",
          "description": "使用紫外线手电照射羊皮手稿，显现隐藏诗句：'东方有兽名麒麟，踏星而来报时运……水关尽头见帝心。'",
          "chapter": 1,
          "prerequisites": [
            "node_inspect_box"
          ],
          "complete_condition": "player.combine(item_uv_lamp, item_manuscript)",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_find_fragment": {
          "id": "node_find_fragment",
          "name": "找到青花碎片",
          "description": "在和义门模型门钉内找到青花瓷碎片，将其拼入大盘，完整星图显现数字序列。",
          "chapter": 1,
          "prerequisites": [
            "node_find_poem"
          ],
          "complete_condition": "player.pickup(item_fragment)",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ch1_complete": {
          "id": "node_ch1_complete",
          "name": "完成展厅调查",
          "description": "与赵教授对话获取关键信息（麒麟=角宿、暗语线索），推理出下一目的地为妙应寺白塔，离开展厅。",
          "chapter": 1,
          "prerequisites": [
            "node_find_fragment"
          ],
          "complete_condition": "npc.zhao_professor.dialogue_state >= 'hint_baita' AND player.action == 'go_to_baita'",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_ch2_star_map": {
          "id": "node_ch2_star_map",
          "name": "拼合星图",
          "description": "在瓷器修复实验室与艾琳娜对话，获取新碎片信息，使用紫外灯发现'正午塔影落于东南方石板上'的线索。",
          "chapter": 2,
          "prerequisites": [
            "node_ch1_complete"
          ],
          "complete_condition": "npc.elena.dialogue_complete AND player.has(item_star_map_info)",
          "is_critical_path": true,
          "is_hidden": false,
          "anti_cheat_lock": true
        },
        "node_escape_chase": {
          "id": "node_escape_chase",
