# ── 必须填写 ──────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxx
SESSION_SECRET_SALT=change_me_random_32bytes_base64
JWT_SECRET=change_me_random_64bytes_base64

# ── 数据库 ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aw:aw_pass@postgres:5432/agentworld
REDIS_URL=redis://redis:6379/0

# ── 可选 ──────────────────────────────────────────────
MAX_SESSIONS_PER_WORLD=50
AGENT_TURN_TIMEOUT_S=120
CHEAT_SEMANTIC_THRESHOLD=0.85
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://localhost:9001
